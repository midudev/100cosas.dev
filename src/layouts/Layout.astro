---
import "../styles/global.css"
import { ClientRouter } from "astro:transitions"

interface Props {
  title?: string
  description?: string
  image?: string
  canonical?: string
  alternateUrl?: string
  ogType?: "website" | "article" | "profile"
  publishedTime?: string
  modifiedTime?: string
  author?: string
  keywords?: string[]
  noindex?: boolean
}

const {
  title = "100cosas.dev | Consejos para Programadores",
  description = 'Una colección interactiva basada en "97 Things Every Programmer Should Know". Lee, aprende y marca tu progreso.',
  image = "/og-image.jpg",
  canonical,
  alternateUrl,
  ogType = "website",
  publishedTime,
  modifiedTime,
  author = "midudev",
  keywords = ["programación", "desarrollo", "software", "consejos", "clean code", "buenas prácticas"],
  noindex = false,
} = Astro.props

const lang = Astro.currentLocale || "es"
const canonicalPath = canonical ?? Astro.url.pathname
const canonicalURL = new URL(canonicalPath, Astro.site)
const fullImageURL = new URL(image, Astro.site).toString()
const skipToContentLabel =
  lang === "es" ? "Saltar al contenido principal" : "Skip to main content"

// Logic for hreflang
const alternateLang = lang === "es" ? "en" : "es"
const alternatePath = alternateUrl ?? (
  lang === "es"
    ? `/en${Astro.url.pathname === "/" ? "" : Astro.url.pathname}`
    : Astro.url.pathname.replace(/^\/en(?=\/|$)/, "") || "/"
)
const alternateURL = new URL(alternatePath, Astro.site)

// Determinar título SEO optimizado
const seoTitle = title.includes("100cosas.dev") ? title : `${title} | 100cosas.dev`

// JSON-LD dinámico según el tipo de página
const baseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "100cosas.dev",
  "alternateName": "100 Cosas que Todo Programador Debería Saber",
  "url": "https://100cosas.dev",
  "description": lang === "es"
    ? "Consejos fundamentales para programadores y desarrolladores de software"
    : "Essential tips for programmers and software developers",
  "inLanguage": [lang === "es" ? "es-ES" : "en-US"],
  "publisher": {
    "@type": "Organization",
    "name": "midudev",
    "url": "https://midu.dev",
    "logo": {
      "@type": "ImageObject",
      "url": "https://100cosas.dev/favicon.svg",
      "width": "512",
      "height": "512"
    },
    "sameAs": [
      "https://twitter.com/midudev",
      "https://github.com/midudev",
      "https://youtube.com/@midudev",
      "https://twitch.tv/midudev"
    ]
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://100cosas.dev/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}

// BreadcrumbList para navegación estructurada
const pathSegments = Astro.url.pathname.split('/').filter(Boolean)
const breadcrumbItems = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Inicio",
    "item": "https://100cosas.dev"
  }
]

if (pathSegments.length > 0) {
  let currentPath = ""
  pathSegments.forEach((segment, index) => {
    currentPath += `/${segment}`
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": index + 2,
      "name": segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
      "item": `https://100cosas.dev${currentPath}`
    })
  })
}

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon y App Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />

    <!-- SEO Meta Tags Básicos -->
    <title>{seoTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={author} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Indexación -->
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="bingbot" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Temática y Color -->
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="msapplication-TileColor" content="#050505" />

    <!-- Geo y Audiencia -->
    <meta name="geo.region" content="ES" />
    <meta name="rating" content="general" />
    <meta name="revisit-after" content="7 days" />

    <!-- i18n Hreflang -->
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL("/", Astro.site)}
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="100cosas.dev" />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "es" ? "en_US" : "es_ES"} />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && (
      <>
        <meta property="article:author" content={author} />
        <meta property="article:section" content="Programación" />
        {keywords.map((keyword) => (
          <meta property="article:tag" content={keyword} />
        ))}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@midudev" />
    <meta name="twitter:creator" content="@midudev" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageURL} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:domain" content="100cosas.dev" />

    <!-- LinkedIn -->
    <meta property="linkedin:owner" content="midudev" />

    <!-- Font preload -->
    <link rel="preload" href="/fonts/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeistPixel-Square.woff2" as="font" type="font/woff2" crossorigin />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(baseJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <a class="skip-link" href="#main-content">{skipToContentLabel}</a>
    <slot />
  </body>
</html>
