---
import "../styles/global.css"
import { ClientRouter } from "astro:transitions"

interface Props {
  title?: string
  description?: string
  image?: string
  canonical?: string
  alternateUrl?: string
  ogType?: "website" | "article" | "profile"
  publishedTime?: string
  modifiedTime?: string
  author?: string
  keywords?: string[]
  noindex?: boolean
}

const {
  title = "100cosas.dev | Consejos para Programadores",
  description = 'Una colección interactiva basada en "97 Things Every Programmer Should Know". Lee, aprende y marca tu progreso.',
  image = "/og-image.jpg",
  canonical,
  alternateUrl,
  ogType = "website",
  publishedTime,
  modifiedTime,
  author = "midudev",
  keywords = ["programación", "desarrollo", "software", "consejos", "clean code", "buenas prácticas"],
  noindex = false,
} = Astro.props

const lang = Astro.currentLocale || "es"
const canonicalPath = canonical ?? Astro.url.pathname
const canonicalURL = new URL(canonicalPath, Astro.site)
const fullImageURL = new URL(image, Astro.site).toString()
const skipToContentLabel =
  lang === "es" ? "Saltar al contenido principal" : "Skip to main content"
const darkThemeColor = "#0b1220"
const lightThemeColor = "#f8fafc"

// Logic for hreflang
const alternateLang = lang === "es" ? "en" : "es"
const alternatePath = alternateUrl ?? (
  lang === "es"
    ? `/en${Astro.url.pathname === "/" ? "" : Astro.url.pathname}`
    : Astro.url.pathname.replace(/^\/en(?=\/|$)/, "") || "/"
)
const alternateURL = new URL(alternatePath, Astro.site)

// Determinar título SEO optimizado
const seoTitle = title.includes("100cosas.dev") ? title : `${title} | 100cosas.dev`

// JSON-LD dinámico según el tipo de página
const baseJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "100cosas.dev",
  "alternateName": "100 Cosas que Todo Programador Debería Saber",
  "url": "https://100cosas.dev",
  "description": lang === "es"
    ? "Consejos fundamentales para programadores y desarrolladores de software"
    : "Essential tips for programmers and software developers",
  "inLanguage": [lang === "es" ? "es-ES" : "en-US"],
  "publisher": {
    "@type": "Organization",
    "name": "midudev",
    "url": "https://midu.dev",
    "logo": {
      "@type": "ImageObject",
      "url": "https://100cosas.dev/favicon.svg",
      "width": "512",
      "height": "512"
    },
    "sameAs": [
      "https://twitter.com/midudev",
      "https://github.com/midudev",
      "https://youtube.com/@midudev",
      "https://twitch.tv/midudev"
    ]
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://100cosas.dev/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}

// BreadcrumbList para navegación estructurada
const pathSegments = Astro.url.pathname.split('/').filter(Boolean)
const breadcrumbItems = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Inicio",
    "item": "https://100cosas.dev"
  }
]

if (pathSegments.length > 0) {
  let currentPath = ""
  pathSegments.forEach((segment, index) => {
    currentPath += `/${segment}`
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": index + 2,
      "name": segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
      "item": `https://100cosas.dev${currentPath}`
    })
  })
}

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
}
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (() => {
        const STORAGE_KEY = "site-theme"
        const DARK_THEME_COLOR = "#0b1220"
        const LIGHT_THEME_COLOR = "#f8fafc"
        const root = document.documentElement

        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark"

        let theme = "dark"
        try {
          const storedTheme = localStorage.getItem(STORAGE_KEY)
          theme = storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : getSystemTheme()
        } catch {
          theme = getSystemTheme()
        }

        root.dataset.theme = theme
        root.style.colorScheme = theme

        const themeColorMeta = document.getElementById("theme-color-meta")
        if (themeColorMeta) {
          themeColorMeta.setAttribute(
            "content",
            theme === "light" ? LIGHT_THEME_COLOR : DARK_THEME_COLOR
          )
        }
      })()
    </script>

    <!-- Favicon y App Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />

    <!-- SEO Meta Tags Básicos -->
    <title>{seoTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={author} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Indexación -->
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="bingbot" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Temática y Color -->
    <meta name="theme-color" id="theme-color-meta" content={darkThemeColor} />
    <meta name="color-scheme" content="dark light" />
    <meta name="msapplication-TileColor" content={lightThemeColor} />

    <!-- Geo y Audiencia -->
    <meta name="geo.region" content="ES" />
    <meta name="rating" content="general" />
    <meta name="revisit-after" content="7 days" />

    <!-- i18n Hreflang -->
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL("/", Astro.site)}
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="100cosas.dev" />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "es" ? "en_US" : "es_ES"} />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && (
      <>
        <meta property="article:author" content={author} />
        <meta property="article:section" content="Programación" />
        {keywords.map((keyword) => (
          <meta property="article:tag" content={keyword} />
        ))}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@midudev" />
    <meta name="twitter:creator" content="@midudev" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageURL} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:domain" content="100cosas.dev" />

    <!-- LinkedIn -->
    <meta property="linkedin:owner" content="midudev" />

    <!-- Font preload -->
    <link rel="preload" href="/fonts/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeistPixel-Square.woff2" as="font" type="font/woff2" crossorigin />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(baseJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

    <ClientRouter fallback="swap" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a class="skip-link" href="#main-content">{skipToContentLabel}</a>
    <svg aria-hidden="true" class="icon-sprite">
      <symbol
        id="icon-eye"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
        <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"></path>
      </symbol>
      <symbol
        id="icon-eye-check"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
        <path d="M11.102 17.957c-3.204 -.307 -5.904 -2.294 -8.102 -5.957c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6a19.5 19.5 0 0 1 -.663 1.032"></path>
        <path d="M15 19l2 2l4 -4"></path>
      </symbol>
    </svg>
    <slot />
    <script>
      const TRANSITION_NAMES = {
        number: "active-tip-number",
        title: "active-tip-title",
        avatar: "active-tip-avatar",
        author: "active-tip-author",
      }

      const STORAGE_KEY = "active-tip-transition-id"
      const LIST_PATHS = new Set(["/", "/es", "/es/", "/en", "/en/"])

      function clearTipTransitionNames(root: ParentNode = document) {
        root.querySelectorAll<HTMLElement>("[data-vt-part]").forEach((element) => {
          element.style.viewTransitionName = ""
        })
      }

      function markTipTransition(root: ParentNode, id: string | null | undefined) {
        if (!id) return false

        const container =
          root.querySelector<HTMLElement>(`.tip-card[data-id="${CSS.escape(id)}"]`) ||
          root.querySelector<HTMLElement>(`[data-tip-id="${CSS.escape(id)}"]`)

        if (!container) return false

        Object.entries(TRANSITION_NAMES).forEach(([part, name]) => {
          const element = container.querySelector<HTMLElement>(`[data-vt-part="${part}"]`)
          if (element) element.style.viewTransitionName = name
        })

        return true
      }

      function getCurrentTipId() {
        return document.querySelector<HTMLElement>("[data-tip-id]")?.dataset.tipId
      }

      function getSourceTipId(sourceElement: EventTarget | null) {
        if (!(sourceElement instanceof Element)) return null
        return sourceElement.closest<HTMLElement>(".tip-card")?.dataset.id || null
      }

      function shouldMarkCurrentTipForLink(link: HTMLAnchorElement) {
        const currentTipId = getCurrentTipId()
        if (!currentTipId) return false

        const url = new URL(link.href, location.href)
        return url.origin === location.origin && LIST_PATHS.has(url.pathname)
      }

      function setStoredTipId(id: string) {
        try {
          sessionStorage.setItem(STORAGE_KEY, id)
        } catch {}
      }

      function getStoredTipId() {
        try {
          return sessionStorage.getItem(STORAGE_KEY)
        } catch {
          return null
        }
      }

      function clearStoredTipId() {
        try {
          sessionStorage.removeItem(STORAGE_KEY)
        } catch {}
      }

      const globalTransitionState = globalThis as typeof globalThis & {
        __tipTransitionsBound?: boolean
      }

      if (!globalTransitionState.__tipTransitionsBound) {
        globalTransitionState.__tipTransitionsBound = true

        document.addEventListener(
          "click",
          (event) => {
            const link = (event.target as Element | null)?.closest("a")
            if (!link || link.target || link.hasAttribute("download")) return

            clearTipTransitionNames()

            const sourceTipId = getSourceTipId(link)
            if (sourceTipId) {
              markTipTransition(document, sourceTipId)
              setStoredTipId(sourceTipId)
              return
            }

            if (shouldMarkCurrentTipForLink(link)) {
              const currentTipId = getCurrentTipId()
              markTipTransition(document, currentTipId)
              if (currentTipId) setStoredTipId(currentTipId)
            }
          },
          { capture: true }
        )

        document.addEventListener("astro:before-swap", (event) => {
          const transitionEvent = event as CustomEvent & {
            sourceElement?: EventTarget | null
            newDocument?: Document
          }
          const newDocument = transitionEvent.newDocument
          if (!newDocument) return

          clearTipTransitionNames(newDocument)

          const sourceTipId = getSourceTipId(transitionEvent.sourceElement)
          const currentTipId = getCurrentTipId()
          const storedTipId = getStoredTipId()
          const targetTipId = newDocument.querySelector<HTMLElement>("[data-tip-id]")?.dataset.tipId
          const nextTipId = sourceTipId || (targetTipId ? null : currentTipId) || storedTipId

          if (nextTipId) {
            markTipTransition(newDocument, nextTipId)
          }
        })

        document.addEventListener("astro:page-load", () => {
          clearTipTransitionNames()
          clearStoredTipId()
        })
      }
    </script>
  </body>
</html>
