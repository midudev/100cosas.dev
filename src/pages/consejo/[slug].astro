---
import { getCollection } from "astro:content"
import TipPage from "../../components/TipPage.astro"

export async function getStaticPaths() {
  const tipsEntries = (
    await getCollection("tips", ({ id }) => {
      return id.startsWith("es/")
    })
  ).sort((a, b) => parseInt(a.data.id) - parseInt(b.data.id))

  return tipsEntries.map((entry, index) => {
    const slug = entry.id.replace(/^es\//, "")
    const prevEntry = index > 0 ? tipsEntries[index - 1] : null
    const nextEntry =
      index < tipsEntries.length - 1 ? tipsEntries[index + 1] : null

    const prev = prevEntry
      ? {
          slug: prevEntry.id.replace(/^es\//, ""),
          title: prevEntry.data.title,
        }
      : null
    const next = nextEntry
      ? {
          slug: nextEntry.id.replace(/^es\//, ""),
          title: nextEntry.data.title,
        }
      : null

    return {
      params: { slug },
      props: {
        entry,
        total: tipsEntries.length,
        prev,
        next,
      },
    }
  })
}

const { entry, total, prev, next } = Astro.props
const { id } = entry.data

// Find the equivalent tip in English for the language switcher
const otherTips = await getCollection("tips", (tip) => {
  return tip.id.startsWith("en/") && tip.data.id === id
})
const englishSlug =
  otherTips.length > 0 ? otherTips[0].id.replace(/^en\//, "") : null
const alternateUrl = englishSlug ? `/en/tip/${englishSlug}` : "/en"
---

<TipPage
  entry={entry}
  total={total}
  alternateUrl={alternateUrl}
  prev={prev}
  next={next}
/>
