---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const tipsEntries = await getCollection('tips');
  return tipsEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { id, title, category, author, authorInitials, categoryColor, authorColor } = entry.data;
---

<Layout title={`${title} | 100cosas.dev`}>
    <Navbar />
    
    <main class="flex-grow max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
        <a href="/" class="inline-flex items-center text-sky-400 hover:text-sky-300 mb-8 transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Volver a la lista
        </a>

        <article class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 md:p-12 backdrop-blur-sm">
            <header class="mb-10">
                <div class="flex flex-wrap gap-4 items-center mb-6">
                    <span class="font-mono text-sm text-slate-500 border border-slate-700 px-3 py-1 rounded">#{id}</span>
                    <span class:list={["font-mono text-sm px-3 py-1 rounded", categoryColor]}>{category}</span>
                </div>
                
                <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-8 leading-tight">
                    {title}
                </h1>

                <div class="flex items-center gap-4 pt-6 border-t border-slate-700/50">
                    <div class:list={["w-12 h-12 rounded-full bg-gradient-to-br flex items-center justify-center text-lg font-bold", authorColor]}>
                        {authorInitials}
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 uppercase tracking-wider">Autor</p>
                        <p class="text-lg text-slate-200 font-medium">{author}</p>
                    </div>
                </div>
            </header>

            <div class="prose prose-invert prose-sky max-w-none 
                prose-headings:text-slate-100 prose-p:text-slate-400 prose-p:leading-relaxed
                prose-strong:text-slate-200 prose-code:text-sky-300
                prose-ul:text-slate-400 prose-li:my-2">
                <Content />
            </div>
        </article>
    </main>

    <Footer />
</Layout>

<script define:vars={{ id }}>
    // Marcar como leído al entrar en la página
    const readTips = JSON.parse(localStorage.getItem('read-tips') || '{}');
    readTips[id] = true;
    localStorage.setItem('read-tips', JSON.stringify(readTips));
</script>
