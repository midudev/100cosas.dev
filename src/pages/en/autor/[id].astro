---
import { getCollection } from "astro:content"
import AuthorPage from "../../../components/AuthorPage.astro"

export async function getStaticPaths() {
  const authorsEntries = await getCollection("authors")

  return authorsEntries.map((entry) => {
    return {
      params: { id: entry.id },
      props: { entry },
    }
  })
}

const { entry } = Astro.props

// Get all tips by this author in English
const allTips = await getCollection("tips", ({ id }) => id.startsWith("en/"))
const authorTips = allTips
  .filter((tip) => tip.data.author === entry.id)
  .sort((a, b) => parseInt(a.data.id) - parseInt(b.data.id))

const alternateUrl = `/autor/${entry.id}`
---

<AuthorPage
  entry={entry}
  authorTips={authorTips}
  totalTips={allTips.length}
  alternateUrl={alternateUrl}
/>
