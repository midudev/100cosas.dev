---
import Layout from "../../layouts/Layout.astro"
import Navbar from "../../components/Navbar.astro"
import Hero from "../../components/Hero.astro"
import BookCTA from "../../components/BookCTA.astro"
import TipCard from "../../components/TipCard.astro"
import Footer from "../../components/Footer.astro"
import { getCollection } from "astro:content"
import { getLangFromUrl, useTranslations } from "../../i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const tipsEntries = await getCollection("tips", ({ id }) => {
  return id.startsWith("es/")
})
// Sort by ID to maintain order
const sortedTips = tipsEntries.sort(
  (a, b) => parseInt(a.data.id) - parseInt(b.data.id)
)
---

<Layout
  title={`${t("hero.title")} ${t("hero.subtitle")} | 100cosas.dev`}
  description={t("hero.description")}
  canonical="/"
  alternateUrl="/en"
  noindex={true}
>
  <Navbar total={sortedTips.length} showSearch />

  <main id="main-content" tabindex="-1" class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 w-full">
    <Hero />
    <BookCTA />

    <div
      id="tips-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-8 lg:gap-x-8 lg:gap-y-10"
    >
      {sortedTips.map((tip) => <TipCard {...tip.data} slug={tip.id} content={tip.body ?? ""} />)}
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const searchInput = document.getElementById("tips-search") as HTMLInputElement | null
  const searchStatus = document.getElementById("tips-search-status")
  const filterButtons = document.querySelectorAll(".filter-btn")
  const tipCards = document.querySelectorAll(".tip-card")

  const normalize = (value: string) =>
    value
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim()

  const applyFilters = () => {
    const activeButton = document.querySelector('.filter-btn[data-active="true"]') as HTMLElement | null
    const activeFilter = activeButton?.dataset.filter || "all"
    const query = normalize(searchInput?.value || "")
    let visibleCount = 0

    tipCards.forEach((card) => {
      const el = card as HTMLElement
      const category = el.dataset.category || ""
      const searchable = normalize(el.dataset.search || "")
      const matchesCategory = activeFilter === "all" || category === activeFilter
      const matchesSearch = query.length === 0 || searchable.includes(query)
      const isVisible = matchesCategory && matchesSearch

      el.style.display = isVisible ? "block" : "none"
      if (isVisible) visibleCount += 1
    })

    if (searchStatus && searchInput) {
      const label = searchStatus.dataset.resultsLabel || "resultados encontrados"
      searchStatus.textContent =
        searchInput.value.trim().length > 0 ? `${visibleCount} ${label}` : ""
    }
  }

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      filterButtons.forEach((btn) => {
        btn.setAttribute("data-active", "false")
        btn.setAttribute("aria-pressed", "false")
        btn.classList.remove(
          "bg-sky-500/10",
          "text-sky-400",
          "border-sky-500/20"
        )
        btn.classList.add("bg-slate-800", "text-slate-400", "border-white/5")
      })

      button.setAttribute("data-active", "true")
      button.setAttribute("aria-pressed", "true")
      button.classList.add("bg-sky-500/10", "text-sky-400", "border-sky-500/20")
      button.classList.remove(
        "bg-slate-800",
        "text-slate-400",
        "border-white/5"
      )
      applyFilters()
    })
  })

  searchInput?.addEventListener("input", applyFilters)

  document.addEventListener("keydown", (event) => {
    const target = event.target as HTMLElement | null
    const tagName = target?.tagName?.toLowerCase()
    const isEditable =
      tagName === "input" ||
      tagName === "textarea" ||
      target?.isContentEditable

    if (event.key === "/" && !isEditable && searchInput) {
      event.preventDefault()
      searchInput.focus()
      searchInput.select()
    }
  })
</script>
