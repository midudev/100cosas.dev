---
import { type CollectionEntry } from "astro:content"
import Layout from "../layouts/Layout.astro"
import Navbar from "./Navbar.astro"
import TipCard from "./TipCard.astro"
import Footer from "./Footer.astro"
import { getRelativeLocaleUrl } from "astro:i18n"
import { useTranslations } from "../i18n/utils"

interface Props {
  entry: CollectionEntry<"authors">
  authorTips: CollectionEntry<"tips">[]
  totalTips: number
  alternateUrl: string
}

const { entry, authorTips, totalTips, alternateUrl } = Astro.props
const { id: authorIdField, name, bio, initials, x, github } = entry.data
const photo = `/authors/${authorIdField}.webp`

const lang = (Astro.currentLocale as "es" | "en") || "es"
const t = useTranslations(lang)
const authorBio = bio[lang] || bio[lang === "es" ? "es" : "en"]
---

<Layout
  title={`${name} | ${t('author.title')} | 100cosas.dev`}
  description={authorBio}
  ogType="profile"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: name,
    description: authorBio,
    image: `https://100cosas.dev${photo}`,
    sameAs: [x, github].filter(Boolean),
  })} />

  <Navbar total={totalTips} alternateUrl={alternateUrl} />

  <main id="main-content" tabindex="-1" class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 py-12 w-full">
    <a
      href={getRelativeLocaleUrl(lang, "/")}
      class="inline-flex items-center text-neutral-500 hover:text-neutral-300 mb-10 transition-colors group text-sm"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 mr-1.5 transform group-hover:-translate-x-1 transition-transform"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      {t('tip.back')}
    </a>

    <header
      class="mb-12"
      itemscope
      itemtype="https://schema.org/Person"
    >
      <div
        class="flex flex-col sm:flex-row gap-5 items-center sm:items-start text-center sm:text-left"
      >
        <div
          class="w-20 h-20 rounded-full bg-neutral-800 flex items-center justify-center text-2xl font-medium text-neutral-400 overflow-hidden shrink-0 ring-2 ring-white/[0.06]"
        >
          {
            photo ? (
              <img
                src={photo}
                alt={name}
                width="80"
                height="80"
                decoding="async"
                class="w-full h-full object-cover"
                itemprop="image"
              />
            ) : (
              initials
            )
          }
        </div>

        <div class="flex-grow">
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-2">
            <h1
              class="text-2xl md:text-3xl font-semibold text-neutral-100"
              itemprop="name"
            >
              {name}
            </h1>

            <div class="flex items-center justify-center sm:justify-start gap-1.5">
              {
                x && (
                  <a
                    href={x}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={lang === "es" ? `${name} en X (se abre en una pestaña nueva)` : `${name} on X (opens in a new tab)`}
                    class="text-neutral-600 hover:text-neutral-300 transition-colors p-1.5"
                    itemprop="sameAs"
                  >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  </a>
                )
              }
              {
                github && (
                  <a
                    href={github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={lang === "es" ? `${name} en GitHub (se abre en una pestaña nueva)` : `${name} on GitHub (opens in a new tab)`}
                    class="text-neutral-600 hover:text-neutral-300 transition-colors p-1.5"
                    itemprop="sameAs"
                  >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
                    </svg>
                  </a>
                )
              }
            </div>
          </div>

          <p
            class="text-sm text-neutral-500 leading-relaxed max-w-2xl"
            itemprop="description"
          >
            {authorBio}
          </p>
        </div>
      </div>
    </header>

    <section>
      <h2
        class="text-lg font-medium text-neutral-200 mb-6 flex items-center gap-3"
      >
        {t('author.tips')} {name}
        <span
          class="font-pixel text-[11px] text-sky-400/50 bg-neutral-900 px-2 py-0.5 rounded-sm border border-white/[0.06]"
        >
          {authorTips.length}
        </span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-8 lg:gap-x-8 lg:gap-y-10">
        {authorTips.map((tip) => <TipCard {...tip.data} slug={tip.id} />)}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
