---
import { type CollectionEntry } from "astro:content"
import Layout from "../layouts/Layout.astro"
import Navbar from "./Navbar.astro"
import TipCard from "./TipCard.astro"
import Footer from "./Footer.astro"
import { getRelativeLocaleUrl } from "astro:i18n"
import { useTranslations } from "../i18n/utils"

interface Props {
  entry: CollectionEntry<"authors">
  authorTips: CollectionEntry<"tips">[]
  totalTips: number
  alternateUrl: string
}

const { entry, authorTips, totalTips, alternateUrl } = Astro.props
const { id: authorIdField, name, bio, initials, x, github } = entry.data
const photo = `/authors/${authorIdField}.webp`

const lang = (Astro.currentLocale as "es" | "en") || "es"
const t = useTranslations(lang)
const authorBio = bio[lang] || bio[lang === "es" ? "es" : "en"]
---

<Layout
  title={`${name} | ${t('author.title')} | 100cosas.dev`}
  description={authorBio}
  ogType="profile"
>
  <!-- Schema.org Microdata -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: name,
    description: authorBio,
    image: `https://100cosas.dev${photo}`,
    sameAs: [x, github].filter(Boolean),
  })} />

  <Navbar total={totalTips} alternateUrl={alternateUrl} />

  <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <a
      href={getRelativeLocaleUrl(lang, "/")}
      class="inline-flex items-center text-sky-400 hover:text-sky-300 mb-8 transition-colors group"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 mr-2 transform group-hover:-translate-x-1 transition-transform"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      {t('tip.back')}
    </a>

    <header
      class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 md:p-12 backdrop-blur-sm mb-12"
      itemscope
      itemtype="https://schema.org/Person"
    >
      <div
        class="flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left"
      >
        <div
          class="w-32 h-32 md:w-48 md:h-48 rounded-2xl bg-slate-700 flex items-center justify-center text-4xl font-bold text-white overflow-hidden shrink-0 shadow-2xl"
        >
          {
            photo ? (
              <img
                src={photo}
                alt={name}
                class="w-full h-full object-cover"
                itemprop="image"
              />
            ) : (
              initials
            )
          }
        </div>

        <div class="flex-grow">
          <h1
            class="text-4xl md:text-5xl font-bold text-slate-100 mb-4"
            itemprop="name"
          >
            {name}
          </h1>
          <p
            class="text-xl text-slate-400 leading-relaxed mb-6 max-w-3xl"
            itemprop="description"
          >
            {authorBio}
          </p>

          <div class="flex flex-wrap justify-center md:justify-start gap-4">
            {
              x && (
                <a
                  href={x}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2 bg-slate-900/50 hover:bg-slate-900 border border-white/5 rounded-lg text-slate-300 hover:text-white transition-all"
                  itemprop="sameAs"
                >
                  <span>Twitter / X</span>
                </a>
              )
            }
            {
              github && (
                <a
                  href={github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2 bg-slate-900/50 hover:bg-slate-900 border border-white/5 rounded-lg text-slate-300 hover:text-white transition-all"
                  itemprop="sameAs"
                >
                  <span>GitHub</span>
                </a>
              )
            }
          </div>
        </div>
      </div>
    </header>

    <section>
      <h2
        class="text-2xl font-bold text-slate-100 mb-8 flex items-center gap-3"
      >
        {t('author.tips')} {name}
        <span
          class="text-sm font-mono font-normal text-slate-500 bg-slate-800 px-2 py-1 rounded"
        >
          {authorTips.length}
        </span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {authorTips.map((tip) => <TipCard {...tip.data} slug={tip.id} />)}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
