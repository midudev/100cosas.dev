---
import { getEntry } from "astro:content"
import { getRelativeLocaleUrl } from "astro:i18n"
import { useTranslations } from "../i18n/utils"

interface Props {
  id: string
  title: string
  category: string
  categoryColor?: string
  author: string
  checked?: boolean
  slug?: string
  isPlaceholder?: boolean
}

const {
  id,
  title,
  category,
  categoryColor = "text-sky-400/80 bg-sky-900/20",
  author: authorId,
  checked = false,
  slug = "#",
  isPlaceholder = false,
} = Astro.props

const lang = (Astro.currentLocale || "es") as "es" | "en"
const t = useTranslations(lang)

let authorName = "Autor"
let authorColor = "from-sky-500 to-blue-600"
let authorPhoto = "/authors/kent-c-dodds.webp"

if (!isPlaceholder) {
  const authorEntry = await getEntry("authors", authorId)

  if (!authorEntry) {
    throw new Error(`Author with id "${authorId}" not found for tip "${id}"`)
  }

  const {
    id: authorIdField,
    name: authorNameData,
    color: authorColorData,
  } = authorEntry.data

  authorName = authorNameData
  authorColor = authorColorData || authorColor
  authorPhoto = `/authors/${authorIdField}.webp`
}

const slugWithoutLang = slug.replace(/^(es|en)\//, "")
const tipPath = lang === "es" ? "consejo" : "tip"
---

<div
  class:list={[
    "tip-card bg-slate-800/50 rounded-xl relative",
    !isPlaceholder && "cursor-pointer group",
    isPlaceholder && "is-placeholder",
  ]}
  data-category={category}
  itemscope
  itemtype="https://schema.org/Article"
>
  {
    isPlaceholder && (
      <div class="absolute inset-0 z-20 flex items-center justify-center bg-slate-900/20 backdrop-blur-[1px]">
        <span class="bg-sky-500 text-white px-3 py-1 rounded-full font-bold text-[10px] uppercase tracking-wider shadow-lg transform -rotate-2 border border-white/20">
          {t("tip.upcoming")}
        </span>
      </div>
    )
  }
  <a
    href={isPlaceholder
      ? null
      : getRelativeLocaleUrl(lang, `/${tipPath}/${slugWithoutLang}`)}
    class:list={[
      "p-6 h-full flex flex-col relative z-0",
      isPlaceholder && "blur-[2px] opacity-40 select-none pointer-events-none",
    ]}
    itemprop="url"
  >
    <div class="card-border-indicator"></div>

    <div class="flex justify-between items-start mb-4">
      <span
        class="font-mono text-xs text-slate-500 border border-slate-700 px-2 py-1 rounded"
        >#{id}</span
      >
      <span
        class:list={["font-mono text-xs px-2 py-1 rounded", categoryColor]}
        itemprop="articleSection"
      >
        {category}
      </span>
    </div>

    <h3
      class="text-xl font-semibold text-slate-100 mb-2 group-hover:text-sky-300 transition-colors text-balance"
      itemprop="headline"
    >
      {title}
    </h3>

    <div
      class="mt-auto pt-6 border-t border-slate-700/50 flex items-center justify-between"
    >
      <div
        class="flex items-center gap-2"
        itemprop="author"
        itemscope
        itemtype="https://schema.org/Person"
      >
        <div
          class:list={[
            "w-8 h-8 rounded-full bg-linear-to-br flex items-center justify-center text-[10px] font-bold text-white overflow-hidden",
            authorColor,
          ]}
        >
          <img
            src={authorPhoto}
            alt={authorName}
            class="w-full h-full object-cover"
            onerror="this.style.display='none'"
            itemprop="image"
          />
        </div>
        <span
          class="text-sm text-slate-400 group-hover:text-slate-200 transition-colors"
          itemprop="name"
        >
          {authorName}
        </span>
      </div>

      <div class="w-24 h-6"></div>
      <!-- Espacio para el checkbox que está absoluto -->
    </div>
  </a>

  <!-- Checkbox area - Absolute positioned so it doesn't trigger the link if clicked precisely -->
  {
    !isPlaceholder && (
      <div class="absolute bottom-6 right-6 z-10 flex items-center gap-3 toggle-container">
        <label class="flex items-center gap-3 cursor-pointer group/checkbox">
          <input
            type="checkbox"
            class="read-toggle sr-only"
            checked={checked}
            data-id={id}
          />
          <span
            class="text-[10px] font-mono uppercase tracking-wider status-text text-slate-500"
            data-pending={t("status.pending")}
            data-completed={t("status.completed")}
          />
          <div class="check-icon w-5 h-5 rounded border border-slate-700 flex items-center justify-center transition-colors group-has-checked/checkbox:bg-sky-500 group-has-checked/checkbox:border-sky-500">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-3 w-3 text-white scale-0 group-has-checked/checkbox:scale-100 transition-transform"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
          </div>
        </label>
      </div>
    )
  }
</div>

<script>
  const handleOnMouseMove = (e: MouseEvent) => {
    const target = e.currentTarget as HTMLElement
    const rect = target.getBoundingClientRect()
    const x = e.clientX - rect.left
    const y = e.clientY - rect.top

    target.style.setProperty("--mouse-x", `${x}px`)
    target.style.setProperty("--mouse-y", `${y}px`)
  }

  const cards = document.querySelectorAll(".tip-card:not(.is-placeholder)")
  cards.forEach((card) => {
    ;(card as HTMLElement).onmousemove = (e) => handleOnMouseMove(e)
  })
</script>
