---
import { getEntry } from "astro:content"

interface Props {
  id: string
  title: string
  category: string
  categoryColor?: string
  author: string
  checked?: boolean
  slug?: string
}

const {
  id,
  title,
  category,
  categoryColor = "text-sky-400/80 bg-sky-900/20",
  author: authorId,
  checked = false,
  slug = "#",
} = Astro.props

const authorEntry = await getEntry("authors", authorId)

if (!authorEntry) {
  throw new Error(`Author with id "${authorId}" not found for tip "${id}"`)
}

const {
  name: authorName,
  initials: authorInitials,
  color: authorColor,
} = authorEntry.data
---

<div
  class="tip-card bg-slate-800/50 rounded-xl cursor-pointer group relative"
  data-category={category}
>
  <a
    href={`/consejo/${slug}`}
    class="block p-6 h-full flex flex-col relative z-0"
  >
    <div class="card-border-indicator"></div>

    <div class="flex justify-between items-start mb-4">
      <span
        class="font-mono text-xs text-slate-500 border border-slate-700 px-2 py-1 rounded"
        >#{id}</span
      >
      <span class:list={["font-mono text-xs px-2 py-1 rounded", categoryColor]}
        >{category}</span
      >
    </div>

    <h3
      class="text-xl font-semibold text-slate-100 mb-2 group-hover:text-sky-300 transition-colors"
    >
      {title}
    </h3>

    <div
      class="mt-auto pt-6 border-t border-slate-700/50 flex items-center justify-between"
    >
      <div class="flex items-center gap-2">
        <div
          class:list={[
            "w-6 h-6 rounded-full bg-gradient-to-br flex items-center justify-center text-[10px] font-bold text-white",
            authorColor,
          ]}
        >
          {authorInitials}
        </div>
        <span
          class="text-sm text-slate-400 group-hover:text-slate-200 transition-colors"
          >{authorName}</span
        >
      </div>

      <div class="w-24 h-6"></div>
      <!-- Espacio para el checkbox que está absoluto -->
    </div>
  </a>

  <!-- Checkbox area - Absolute positioned so it doesn't trigger the link if clicked precisely -->
  <div
    class="absolute bottom-6 right-6 z-10 flex items-center gap-3 toggle-container"
  >
    <label class="flex items-center gap-3 cursor-pointer">
      <input
        type="checkbox"
        class="read-toggle sr-only"
        checked={checked}
        data-id={id}
      />
      <span
        class="text-[10px] font-mono uppercase tracking-wider status-text text-slate-500"
      ></span>
      <div
        class="check-icon w-5 h-5 rounded border border-slate-700 flex items-center justify-center transition-colors group-has-[:checked]:bg-sky-500 group-has-[:checked]:border-sky-500"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-3 w-3 text-white scale-0 group-has-[:checked]:scale-100 transition-transform"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
    </label>
  </div>
</div>

<script>
  const handleOnMouseMove = (e: MouseEvent) => {
    const target = e.currentTarget as HTMLElement
    const rect = target.getBoundingClientRect()
    const x = e.clientX - rect.left
    const y = e.clientY - rect.top

    target.style.setProperty("--mouse-x", `${x}px`)
    target.style.setProperty("--mouse-y", `${y}px`)
  }

  const cards = document.querySelectorAll(".tip-card")
  cards.forEach((card) => {
    ;(card as HTMLElement).onmousemove = (e) => handleOnMouseMove(e)
  })
</script>
