---
import { getEntry, getCollection, render, type CollectionEntry } from "astro:content"
import Layout from "../layouts/Layout.astro"
import Navbar from "./Navbar.astro"
import Footer from "./Footer.astro"
import { getRelativeLocaleUrl } from "astro:i18n"
import { useTranslations } from "../i18n/utils"

interface TipNavItem {
  slug: string
  title: string
}

interface Props {
  entry: CollectionEntry<"tips">
  total: number
  alternateUrl: string
  prev?: TipNavItem | null
  next?: TipNavItem | null
}

const { entry, total, alternateUrl, prev, next } = Astro.props
const { Content } = await render(entry)
const { id, title, category, author: authorId, categoryColor } = entry.data
const description = (entry.body ?? "").slice(0, 160).replace(/[#>]/g, "").trim()

const lang = (Astro.currentLocale as "es" | "en") || "es"
const t = useTranslations(lang)
const tipPath = lang === "es" ? "consejo" : "tip"

const authorEntry = await getEntry("authors", authorId)

if (!authorEntry) {
  throw new Error(`Author with id "${authorId}" not found for tip "${id}"`)
}

const {
  name: authorName,
  initials: authorInitials,
} = authorEntry.data
const authorPhoto = `/authors/${authorEntry.data.id}.webp`

const allTips = await getCollection("tips", ({ id: tipId }) =>
  tipId.startsWith(`${lang}/`)
)
const authorTips = allTips
  .filter((tip) => tip.data.author === authorId && tip.data.id !== id)
  .sort((a, b) => parseInt(a.data.id) - parseInt(b.data.id))
  .slice(0, 5)

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  image: `https://100cosas.dev/authors/${authorEntry.data.id}.webp`,
  author: {
    "@type": "Person",
    name: authorName,
    url: `https://100cosas.dev/${lang === 'es' ? 'autor' : 'en/autor'}/${authorId}`,
  },
  publisher: {
    "@type": "Organization",
    name: "100cosas.dev",
    logo: {
      "@type": "ImageObject",
      url: "https://100cosas.dev/favicon.svg",
    },
  },
}
---

<Layout
  title={`${title} | 100cosas.dev`}
  description={description}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Navbar total={total} alternateUrl={alternateUrl} />

  <main id="main-content" tabindex="-1" class="grow max-w-6xl mx-auto px-4 sm:px-6 py-10 w-full">
    <a
      href={getRelativeLocaleUrl(lang, "/")}
      class="inline-flex items-center text-neutral-500 hover:text-neutral-300 mb-8 transition-colors group text-sm"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 mr-1.5 transform group-hover:-translate-x-1 transition-transform"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      {t('tip.back')}
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-10 lg:gap-16 items-start">
      <!-- Article -->
      <article
        class="max-w-[65ch]"
        itemscope
        itemtype="https://schema.org/Article"
      >
        <header class="mb-10">
          <div class="flex items-center gap-2 mb-5 text-[12px]">
            <span class="font-pixel text-sky-400/50" style={`view-transition-name: tip-number-${id}`}>#{id}</span>
            <span class="font-pixel text-neutral-700">·</span>
            <span
              class:list={["px-2 py-0.5 rounded-sm", categoryColor]}
              itemprop="articleSection"
              style={`view-transition-name: tip-category-${id}`}>{category}</span
            >
          </div>

          <h1
            class="text-2xl md:text-3xl font-semibold text-neutral-100 mb-6 leading-tight text-balance"
            itemprop="headline"
            style={`view-transition-name: tip-title-${id}`}
          >
            {title}
          </h1>

          <a
            href={getRelativeLocaleUrl(lang, `/autor/${authorId}`)}
            class="inline-flex items-center gap-3 hover:opacity-80 transition-opacity group"
            itemprop="author"
            itemscope
            itemtype="https://schema.org/Person"
          >
            <div
              class="w-8 h-8 rounded-full bg-neutral-800 flex items-center justify-center text-xs font-medium text-neutral-400 overflow-hidden"
              style={`view-transition-name: tip-avatar-${id}`}
            >
              {
                authorPhoto ? (
                  <img
                    src={authorPhoto}
                    alt={authorName}
                    class="w-full h-full object-cover"
                    itemprop="image"
                  />
                ) : (
                  authorInitials
                )
              }
            </div>
            <span
              class="text-sm text-neutral-400 group-hover:text-sky-400 transition-colors"
              itemprop="name"
              style={`view-transition-name: tip-author-${id}`}
            >
              {authorName}
            </span>
          </a>
        </header>

        <div
          class="prose prose-invert prose-sky max-w-none
                  prose-headings:text-neutral-200 prose-headings:font-semibold
                  prose-p:text-neutral-400 prose-p:leading-[1.8] prose-p:text-[15px]
                  prose-strong:text-neutral-200
                  prose-code:text-sky-300
                  prose-ul:text-neutral-400 prose-li:my-1.5
                  prose-ol:text-neutral-400
                  prose-pre:bg-[#050505] prose-pre:border-0 prose-pre:rounded-none prose-pre:my-6
                  prose-a:text-sky-400 prose-a:no-underline hover:prose-a:underline"
          itemprop="articleBody"
        >
          <Content />
        </div>
      </article>

      <!-- Aside -->
      <aside class="lg:sticky lg:top-20 space-y-8 lg:border-l lg:border-white/[0.04] lg:pl-8">
        <!-- Author card -->
        <div>
          <p class="text-[10px] text-neutral-600 uppercase tracking-widest mb-3">{t('tip.author')}</p>
          <a
            href={getRelativeLocaleUrl(lang, `/autor/${authorId}`)}
            class="flex items-center gap-3 group"
          >
            <div class="w-10 h-10 rounded-full bg-neutral-800 overflow-hidden shrink-0">
              {
                authorPhoto ? (
                  <img src={authorPhoto} alt={authorName} class="w-full h-full object-cover" />
                ) : (
                  <span class="w-full h-full flex items-center justify-center text-sm text-neutral-400">{authorInitials}</span>
                )
              }
            </div>
            <div>
              <p class="text-sm text-neutral-200 group-hover:text-sky-400 transition-colors font-medium">{authorName}</p>
              <p class="text-[11px] text-neutral-600">{t('tip.view_profile')} &rarr;</p>
            </div>
          </a>
        </div>

        <!-- More by this author -->
        {authorTips.length > 0 && (
          <div>
            <p class="text-[10px] text-neutral-600 uppercase tracking-widest mb-3">{t('tip.more_by_author')}</p>
            <ul class="space-y-2">
              {authorTips.map((tip) => {
                const tipSlug = tip.id.replace(/^(es|en)\//, "")
                return (
                  <li>
                    <a
                      href={getRelativeLocaleUrl(lang, `/${tipPath}/${tipSlug}`)}
                      class="flex items-baseline gap-2 text-[13px] text-neutral-500 hover:text-sky-400 transition-colors group"
                    >
                      <span class="font-pixel text-[10px] text-sky-400/40 shrink-0">#{tip.data.id}</span>
                      <span class="group-hover:text-sky-400 leading-snug">{tip.data.title}</span>
                    </a>
                  </li>
                )
              })}
            </ul>
          </div>
        )}

        <!-- Category -->
        <div>
          <p class="text-[10px] text-neutral-600 uppercase tracking-widest mb-3">{t('tip.category_label')}</p>
          <span class:list={["text-[12px] px-2 py-0.5 rounded-sm", categoryColor]}>{category}</span>
        </div>

        <!-- Buy book CTA -->
        <a
          href="#"
          class="group flex items-center gap-3 p-3.5 rounded-xl border border-amber-500/20 bg-gradient-to-r from-amber-500/[0.07] to-orange-500/[0.07] hover:from-amber-500/15 hover:to-orange-500/15 hover:border-amber-500/30 transition-all"
        >
          <span class="flex items-center justify-center size-9 rounded-lg bg-amber-500/15 text-amber-400 shrink-0 group-hover:bg-amber-500/20 transition-colors">
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 016.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" />
              <path d="M8 7h8" />
              <path d="M8 11h6" />
            </svg>
          </span>
          <span class="flex-1 min-w-0">
            <span class="block text-[13px] font-medium text-amber-100">{t("book.buy")}</span>
            <span class="block text-[11px] text-amber-400/60">{t("book.buy_desc")}</span>
          </span>
          <svg class="size-3.5 text-amber-400/40 shrink-0" viewBox="0 0 16 16" fill="currentColor">
            <path d="M4.53 4.75A.75.75 0 015.28 4h6.01a.75.75 0 01.75.75v6.01a.75.75 0 01-1.5 0V6.31l-5.263 5.263a.75.75 0 01-1.06-1.06L9.44 5.25H5.28a.75.75 0 01-.75-.75z" />
          </svg>
        </a>

        <!-- Prev / Next navigation -->
        <nav class="space-y-2">
          {prev && (
            <a
              href={getRelativeLocaleUrl(lang, `/${tipPath}/${prev.slug}`)}
              class="block group"
            >
              <span class="text-[10px] text-neutral-700 uppercase tracking-widest">{t("tip.prev")}</span>
              <span class="text-[13px] text-neutral-500 group-hover:text-sky-400 transition-colors flex items-center gap-1.5 leading-snug mt-0.5">
                <span class="shrink-0">&larr;</span>
                {prev.title}
              </span>
            </a>
          )}
          {next && (
            <a
              href={getRelativeLocaleUrl(lang, `/${tipPath}/${next.slug}`)}
              class="block group"
            >
              <span class="text-[10px] text-neutral-700 uppercase tracking-widest">{t("tip.next")}</span>
              <span class="text-[13px] text-neutral-500 group-hover:text-sky-400 transition-colors flex items-center gap-1.5 leading-snug mt-0.5">
                {next.title}
                <span class="shrink-0">&rarr;</span>
              </span>
            </a>
          )}
        </nav>
      </aside>
    </div>
  </main>

  <Footer />
</Layout>

<script define:vars={{ id }}>
  const STORAGE_KEY = "read-tips"
  const stored = localStorage.getItem(STORAGE_KEY)
  const readTips = stored ? JSON.parse(stored) : []
  if (!readTips.includes(id)) {
    readTips.push(id)
    localStorage.setItem(STORAGE_KEY, JSON.stringify(readTips))
  }
</script>
