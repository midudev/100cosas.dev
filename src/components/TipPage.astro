---
import { getEntry, type CollectionEntry } from "astro:content"
import Layout from "../layouts/Layout.astro"
import Navbar from "./Navbar.astro"
import Footer from "./Footer.astro"
import { getRelativeLocaleUrl } from "astro:i18n"
import { useTranslations } from "../i18n/utils"

interface TipNavItem {
  slug: string
  title: string
}

interface Props {
  entry: CollectionEntry<"tips">
  total: number
  alternateUrl: string
  prev?: TipNavItem | null
  next?: TipNavItem | null
}

const { entry, total, alternateUrl, prev, next } = Astro.props
const { Content } = await entry.render()
const { id, title, category, author: authorId, categoryColor } = entry.data

const lang = (Astro.currentLocale as "es" | "en") || "es"
const t = useTranslations(lang)
const tipPath = lang === "es" ? "consejo" : "tip"

const authorEntry = await getEntry("authors", authorId)

if (!authorEntry) {
  throw new Error(`Author with id "${authorId}" not found for tip "${id}"`)
}

const {
  name: authorName,
  initials: authorInitials,
  color: authorColor,
} = authorEntry.data
const authorPhoto = `/authors/${authorEntry.data.id}.webp`

// Schema.org Article data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: entry.body.slice(0, 160).replace(/[#>]/g, "").trim(),
  image: `https://100cosas.dev/authors/${authorEntry.data.id}.webp`,
  author: {
    "@type": "Person",
    name: authorName,
    url: `https://100cosas.dev/${lang === 'es' ? 'autor' : 'en/autor'}/${authorId}`,
  },
  publisher: {
    "@type": "Organization",
    name: "100cosas.dev",
    logo: {
      "@type": "ImageObject",
      url: "https://100cosas.dev/favicon.svg",
    },
  },
}
---

<Layout
  title={`${title} | 100cosas.dev`}
  description={entry.body.slice(0, 160).replace(/[#>]/g, "").trim()}
  ogType="article"
>
  <!-- Schema.org Microdata -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Navbar total={total} alternateUrl={alternateUrl} />

  <main class="grow max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
    <a
      href={getRelativeLocaleUrl(lang, "/")}
      class="inline-flex items-center text-sky-400 hover:text-sky-300 mb-8 transition-colors group"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 mr-2 transform group-hover:-translate-x-1 transition-transform"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      {t('tip.back')}
    </a>

    <article
      class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 md:p-12 backdrop-blur-sm"
      itemscope
      itemtype="https://schema.org/Article"
    >
      <header class="mb-10">
        <div class="flex flex-wrap gap-4 items-center mb-6">
          <span
            class="font-mono text-sm text-slate-500 border border-slate-700 px-3 py-1 rounded"
            >#{id}</span
          >
          <span
            class:list={["font-mono text-sm px-3 py-1 rounded", categoryColor]}
            itemprop="articleSection">{category}</span
          >
        </div>

        <h1
          class="text-4xl md:text-5xl font-bold text-slate-100 mb-8 leading-tight text-balance"
          itemprop="headline"
        >
          {title}
        </h1>

        <a
          href={getRelativeLocaleUrl(lang, `/autor/${authorId}`)}
          class="inline-flex items-center gap-4 pt-6 border-t border-slate-700/50 hover:opacity-80 transition-opacity group"
          itemprop="author"
          itemscope
          itemtype="https://schema.org/Person"
        >
          <div
            class:list={[
              "w-12 h-12 rounded-full bg-linear-to-br flex items-center justify-center text-lg font-bold text-white overflow-hidden",
              authorColor,
            ]}
          >
            {
              authorPhoto ? (
                <img
                  src={authorPhoto}
                  alt={authorName}
                  class="w-full h-full object-cover"
                  itemprop="image"
                />
              ) : (
                authorInitials
              )
            }
          </div>
          <div>
            <p class="text-sm text-slate-500 uppercase tracking-wider">
              {t('tip.author')}
            </p>
            <p
              class="text-lg text-slate-200 font-medium group-hover:text-sky-400 transition-colors"
              itemprop="name"
            >
              {authorName}
            </p>
          </div>
        </a>
      </header>

      <div
        class="prose prose-invert prose-sky max-w-none
                prose-headings:text-slate-100 prose-p:text-slate-400 prose-p:leading-relaxed
                prose-strong:text-slate-200 prose-code:text-sky-300
                prose-ul:text-slate-400 prose-li:my-2
                prose-pre:bg-slate-900/50 prose-pre:border prose-pre:border-white/5"
        itemprop="articleBody"
      >
        <Content />
      </div>

      <nav
        class="mt-12 pt-12 border-t border-slate-700/50 flex flex-col sm:flex-row gap-4 justify-between"
      >
        {
          prev ? (
            <a
              href={getRelativeLocaleUrl(lang, `/${tipPath}/${prev.slug}`)}
              class="flex-1 group p-4 rounded-xl border border-slate-700/50 hover:border-sky-500/50 hover:bg-sky-500/5 transition-all text-left"
            >
              <span class="text-xs text-slate-500 uppercase tracking-wider mb-1 block">
                {t("tip.prev")}
              </span>
              <span class="text-slate-200 font-medium group-hover:text-sky-400 transition-colors flex items-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 mr-2"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 19l-7-7 7-7"
                  />
                </svg>
                {prev.title}
              </span>
            </a>
          ) : (
            <div class="flex-1" />
          )
        }

        {
          next ? (
            <a
              href={getRelativeLocaleUrl(lang, `/${tipPath}/${next.slug}`)}
              class="flex-1 group p-4 rounded-xl border border-slate-700/50 hover:border-sky-500/50 hover:bg-sky-500/5 transition-all text-right"
            >
              <span class="text-xs text-slate-500 uppercase tracking-wider mb-1 block">
                {t("tip.next")}
              </span>
              <span class="text-slate-200 font-medium group-hover:text-sky-400 transition-colors flex items-center justify-end">
                {next.title}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 ml-2"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </span>
            </a>
          ) : (
            <div class="flex-1" />
          )
        }
      </nav>
    </article>
  </main>

  <Footer />
</Layout>

<script define:vars={{ id }}>
  // Marcar como leído al entrar en la página
  const STORAGE_KEY = "read-tips"
  const stored = localStorage.getItem(STORAGE_KEY)
  const readTips = stored ? JSON.parse(stored) : []
  if (!readTips.includes(id)) {
    readTips.push(id)
    localStorage.setItem(STORAGE_KEY, JSON.stringify(readTips))
  }
</script>
