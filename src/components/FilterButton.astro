---
interface Props {
  active?: boolean
  filter?: string
}

const { active = false, filter } = Astro.props
---

<button
  type="button"
  class:list={[
    "filter-btn whitespace-nowrap px-2.5 py-1 text-[11px] transition-colors cursor-pointer shrink-0",
    active
      ? "text-sky-400"
      : "text-neutral-600 hover:text-neutral-300",
  ]}
  data-filter={filter}
  data-active={active ? "true" : "false"}
  aria-pressed={active ? "true" : "false"}
>
  <slot />
</button>
