---
import { useTranslations } from "../i18n/utils"
import FilterButton from "./FilterButton.astro"
import { getCollection } from "astro:content"

import { ui, defaultLang } from "../i18n/ui"

const lang = (Astro.currentLocale || "es") as "es" | "en"
const t = useTranslations(lang)

const tipsEntries = await getCollection("tips", ({ id }) => {
  return id.startsWith(`${lang}/`)
})

const usedCategories = new Set(tipsEntries.map((tip) => tip.data.category))

const CATEGORY_KEYS = [
  "clean_code",
  "principles",
  "architecture",
  "professionalism",
  "design",
  "testing",
  "practices",
  "soft_skills",
  "paradigm",
  "tools",
  "automation",
  "fundamentals",
  "typing",
  "ux_ui",
  "refactor",
  "ddd",
  "dry",
] as const

const displayedCategories = CATEGORY_KEYS.map((key) => {
  const translationKey = `cat.${key}` as keyof (typeof ui)[typeof defaultLang]
  return t(translationKey)
}).filter((name) => usedCategories.has(name)) as string[]

// Add any categories that might not be in our predefined list but are used
const otherCategories = [...usedCategories].filter(
  (name) => !displayedCategories.includes(name)
)

const allToDisplay = [...displayedCategories, ...otherCategories]
---

<header
  class="relative pt-24 pb-16 px-4 text-center max-w-5xl mx-auto overflow-hidden"
>
  <!-- Spotlight background effect -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 pointer-events-none"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-[200px] bg-sky-500/10 blur-[120px] rounded-full"
    >
    </div>
  </div>

  <h1
    class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1]"
  >
    {t("hero.title")}<br />
    <span
      class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-blue-500 to-sky-400 bg-[length:200%_auto] animate-gradient"
      >{t("hero.subtitle")}</span
    >
  </h1>

  <p
    class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed text-balance"
  >
    {t("hero.description")}
  </p>

  <!-- Filtros -->
  <div class="relative group">
    <div
      class="absolute -inset-1 bg-gradient-to-r from-sky-500/20 to-blue-500/20 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
    >
    </div>
    <div
      class="relative flex flex-wrap justify-center gap-2 font-mono text-sm py-2 px-4 bg-slate-900/40 backdrop-blur-sm rounded-2xl border border-white/5 shadow-2xl"
      id="filter-container"
    >
      <FilterButton active filter="all">{t("filter.all")}</FilterButton>
      {
        allToDisplay.map((categoryName) => (
          <FilterButton filter={categoryName}>{categoryName}</FilterButton>
        ))
      }
    </div>
  </div>
</header>

<style>
  @keyframes gradient {
    0% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
    100% {
      background-position: 0% center;
    }
  }
  .animate-gradient {
    animation: gradient 8s linear infinite;
  }
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }
</style>
