---
import { useTranslations } from "../i18n/utils"

const lang = (Astro.currentLocale || "es") as "es" | "en"
const t = useTranslations(lang)
---

<header class="relative pt-16 pb-10 px-4 max-w-4xl mx-auto">
  <h1 class="flex items-center gap-5 md:gap-7 justify-center mb-5">
    <span class="font-pixel text-8xl md:text-[10rem] text-sky-400 leading-[0.75] tracking-tighter select-none shrink-0">
      100
    </span>
    <span class="text-[1.4rem] md:text-[2.1rem] leading-[1.2] tracking-tight">
      <span class="text-neutral-500">{t("hero.headline_pre")}</span><br />
      <span class="text-neutral-100 font-medium">{t("hero.headline_accent")}</span><br />
      <span class="text-neutral-500">{t("hero.headline_post")}</span>
    </span>
  </h1>

  <p class="text-center text-neutral-500 text-xs tracking-widest uppercase">
    {t("hero.title")} <span class="text-neutral-300">{t("hero.subtitle")}</span>
  </p>
</header>
