---
import { useTranslations } from "../i18n/utils"
import FilterButton from "./FilterButton.astro"

const lang = (Astro.currentLocale || "es") as "es" | "en"
const t = useTranslations(lang)
---

<header
  class="relative pt-24 pb-16 px-4 text-center max-w-5xl mx-auto overflow-hidden"
>
  <!-- Spotlight background effect -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 pointer-events-none"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-[200px] bg-sky-500/10 blur-[120px] rounded-full"
    >
    </div>
  </div>

  <h1
    class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1]"
  >
    {t("hero.title")}<br />
    <span
      class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-blue-500 to-sky-400 bg-[length:200%_auto] animate-gradient"
      >{t("hero.subtitle")}</span
    >
  </h1>

  <p
    class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed"
  >
    {t("hero.description")}
  </p>

  <!-- Filtros -->
  <div class="relative group">
    <div
      class="absolute -inset-1 bg-gradient-to-r from-sky-500/20 to-blue-500/20 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
    >
    </div>
    <div
      class="relative flex flex-wrap justify-center gap-2 font-mono text-sm py-2 px-4 bg-slate-900/40 backdrop-blur-sm rounded-2xl border border-white/5 shadow-2xl"
      id="filter-container"
    >
      <FilterButton active filter="all">{t("filter.all")}</FilterButton>
      <FilterButton filter={t("cat.clean_code")}
        >{t("cat.clean_code")}</FilterButton
      >
      <FilterButton filter={t("cat.principles")}
        >{t("cat.principles")}</FilterButton
      >
      <FilterButton filter={t("cat.architecture")}
        >{t("cat.architecture")}</FilterButton
      >
      <FilterButton filter={t("cat.professionalism")}
        >{t("cat.professionalism")}</FilterButton
      >
      <FilterButton filter={t("cat.design")}>{t("cat.design")}</FilterButton>
      <FilterButton filter={t("cat.testing")}>{t("cat.testing")}</FilterButton>
      <FilterButton filter={t("cat.practices")}
        >{t("cat.practices")}</FilterButton
      >
      <FilterButton filter={t("cat.soft_skills")}
        >{t("cat.soft_skills")}</FilterButton
      >
      <FilterButton filter={t("cat.paradigm")}>{t("cat.paradigm")}</FilterButton
      >
      <FilterButton filter={t("cat.tools")}>{t("cat.tools")}</FilterButton>
      <FilterButton filter={t("cat.automation")}
        >{t("cat.automation")}</FilterButton
      >
      <FilterButton filter={t("cat.fundamentals")}
        >{t("cat.fundamentals")}</FilterButton
      >
      <FilterButton filter={t("cat.typing")}>{t("cat.typing")}</FilterButton>
      <FilterButton filter={t("cat.ux_ui")}>{t("cat.ux_ui")}</FilterButton>
      <FilterButton filter={t("cat.refactor")}>{t("cat.refactor")}</FilterButton
      >
      <FilterButton filter={t("cat.ddd")}>{t("cat.ddd")}</FilterButton>
      <FilterButton filter={t("cat.dry")}>{t("cat.dry")}</FilterButton>
    </div>
  </div>
</header>

<style>
  @keyframes gradient {
    0% {
      background-position: 0% center;
    }
    50% {
      background-position: 100% center;
    }
    100% {
      background-position: 0% center;
    }
  }
  .animate-gradient {
    animation: gradient 8s linear infinite;
  }
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }
</style>
