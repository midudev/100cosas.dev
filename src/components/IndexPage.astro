---
import Layout from "../layouts/Layout.astro"
import Navbar from "./Navbar.astro"
import Hero from "./Hero.astro"
import BookCTA from "./BookCTA.astro"
import FilterBar from "./FilterBar.astro"
import TipCard from "./TipCard.astro"
import Footer from "./Footer.astro"
import { type CollectionEntry } from "astro:content"
import { useTranslations } from "../i18n/utils"

interface Props {
  sortedTips: CollectionEntry<"tips">[]
}

const { sortedTips } = Astro.props
const lang = (Astro.currentLocale as "es" | "en") || "es"
const t = useTranslations(lang)

const allTips = Array.from({ length: 100 }, (_, i) => {
  const tipId = (i + 1).toString().padStart(2, "0")
  const existingTip = sortedTips.find((tip) => tip.data.id === tipId)

  if (existingTip) {
    return {
      ...existingTip.data,
      slug: existingTip.id,
      content: existingTip.body ?? "",
      isPlaceholder: false,
    }
  }

  return {
    id: tipId,
    title: t("tip.upcoming"),
    category: "???",
    author: "midudev",
    content: "",
    isPlaceholder: true,
  }
})
---

<Layout
  title={`${t("hero.title")} ${t("hero.subtitle")} | 100cosas.dev`}
  description={t("hero.description")}
>
  <Navbar total={sortedTips.length} showSearch />

  <main id="main-content" tabindex="-1" class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 pb-24 w-full">
    <Hero />
    <BookCTA />
    <FilterBar />

    <div
      id="tips-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-0"
    >
      {allTips.map((tip) => <TipCard {...tip} />)}
    </div>
  </main>

  <Footer />
</Layout>

<script>
  function initSearch() {
    const searchInput = document.getElementById("tips-search") as HTMLInputElement | null
    const searchStatus = document.getElementById("tips-search-status")
    const filterButtons = document.querySelectorAll(".filter-btn")
    const tipCards = document.querySelectorAll(".tip-card")

    if (!searchInput) return

    const normalize = (value: string) =>
      value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim()

    const applyFilters = () => {
      const activeButton = document.querySelector('.filter-btn[data-active="true"]') as HTMLElement | null
      const activeFilter = activeButton?.dataset.filter || "all"
      const query = normalize(searchInput.value || "")
      let visibleCount = 0

      tipCards.forEach((card) => {
        const el = card as HTMLElement
        const category = el.dataset.category || ""
        const searchable = normalize(el.dataset.search || "")
        const matchesCategory = activeFilter === "all" || category === activeFilter
        const matchesSearch = query.length === 0 || searchable.includes(query)
        const isVisible = matchesCategory && matchesSearch

        el.style.display = isVisible ? "block" : "none"
        if (isVisible) visibleCount += 1
      })

      if (searchStatus) {
        const label = searchStatus.dataset.resultsLabel || "resultados encontrados"
        searchStatus.textContent =
          searchInput.value.trim().length > 0 ? `${visibleCount} ${label}` : ""
      }
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        filterButtons.forEach((btn) => {
          btn.setAttribute("data-active", "false")
          btn.setAttribute("aria-pressed", "false")
          btn.classList.remove("text-sky-400")
          btn.classList.add("text-neutral-600")
        })

        button.setAttribute("data-active", "true")
        button.setAttribute("aria-pressed", "true")
        button.classList.add("text-sky-400")
        button.classList.remove("text-neutral-600")
        applyFilters()
      })
    })

    searchInput.addEventListener("input", applyFilters)
  }

  function handleSearchKeydown(event: KeyboardEvent) {
    const target = event.target as HTMLElement | null
    const tagName = target?.tagName?.toLowerCase()
    const isEditable =
      tagName === "input" ||
      tagName === "textarea" ||
      target?.isContentEditable

    if (event.key === "/" && !isEditable) {
      const searchInput = document.getElementById("tips-search") as HTMLInputElement | null
      if (searchInput) {
        event.preventDefault()
        searchInput.focus()
        searchInput.select()
      }
    }
  }

  document.removeEventListener("keydown", handleSearchKeydown)
  document.addEventListener("keydown", handleSearchKeydown)

  initSearch()
  document.addEventListener("astro:page-load", initSearch)
</script>
