---
import Layout from "../layouts/Layout.astro"
import Navbar from "./Navbar.astro"
import Hero from "./Hero.astro"
import BookCTA from "./BookCTA.astro"
import FilterBar from "./FilterBar.astro"
import TipCard from "./TipCard.astro"
import Footer from "./Footer.astro"
import { type CollectionEntry } from "astro:content"
import { useTranslations } from "../i18n/utils"

interface Props {
  sortedTips: CollectionEntry<"tips">[]
  canonical?: string
  alternateUrl?: string
  noindex?: boolean
}

const { sortedTips, canonical, alternateUrl, noindex = false } = Astro.props
const lang = (Astro.currentLocale as "es" | "en") || "es"
const t = useTranslations(lang)
const searchIndexUrl = lang === "es" ? "/search-index.json" : "/en/search-index.json"

const allTips = Array.from({ length: 100 }, (_, i) => {
  const tipId = (i + 1).toString().padStart(2, "0")
  const existingTip = sortedTips.find((tip) => tip.data.id === tipId)

  if (existingTip) {
    return {
      ...existingTip.data,
      slug: existingTip.id,
      content: existingTip.body ?? "",
      isPlaceholder: false,
    }
  }

  return {
    id: tipId,
    title: t("tip.upcoming"),
    category: "???",
    author: "midudev",
    content: "",
    isPlaceholder: true,
  }
})
---

<Layout
  title={`${t("hero.title")} ${t("hero.subtitle")} | 100cosas.dev`}
  description={t("hero.description")}
  canonical={canonical}
  alternateUrl={alternateUrl}
  noindex={noindex}
>
  <Navbar total={sortedTips.length} showSearch />

  <main
    id="main-content"
    tabindex="-1"
    class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 w-full"
    data-search-index-url={searchIndexUrl}
  >
    <Hero />
    <BookCTA />
    <FilterBar />

    <div
      id="tips-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-8 lg:gap-x-8 lg:gap-y-10"
    >
      {allTips.map((tip) => <TipCard {...tip} />)}
    </div>
  </main>

  <Footer />
</Layout>

<script>
  type SearchRecord = {
    id: string
    text: string
  }

  type SearchState = {
    index: Map<string, string> | null
    indexPromise: Promise<Map<string, string>> | null
  }

  const searchState = ((globalThis as typeof globalThis & {
    __tipsSearchState?: SearchState
  }).__tipsSearchState ??= {
    index: null,
    indexPromise: null,
  })

  const normalizeSearch = (value: string) =>
    value
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^\p{Letter}\p{Number}\s#-]/gu, " ")
      .replace(/\s+/g, " ")
      .trim()

  async function loadSearchIndex() {
    if (searchState.index) return searchState.index

    if (!searchState.indexPromise) {
      const main = document.getElementById("main-content")
      const searchIndexUrl = main?.dataset.searchIndexUrl

      if (!searchIndexUrl) return new Map<string, string>()

      searchState.indexPromise = fetch(searchIndexUrl, {
        headers: {
          accept: "application/json",
        },
      })
        .then((response) => {
          if (!response.ok) throw new Error("Search index request failed")
          return response.json() as Promise<{ records: SearchRecord[] }>
        })
        .then(({ records }) => {
          const index = new Map(records.map((record) => [record.id, record.text]))
          searchState.index = index
          return index
        })
        .catch(() => {
          const fallback = new Map<string, string>()
          searchState.index = fallback
          return fallback
        })
    }

    return searchState.indexPromise
  }

  function initSearch() {
    const searchInput = document.getElementById("tips-search") as HTMLInputElement | null
    const searchStatus = document.getElementById("tips-search-status")
    const filterContainer = document.getElementById("filter-container")
    const tipCards = document.querySelectorAll(".tip-card")

    if (!searchInput) return

    const applyFilters = () => {
      const activeButton = document.querySelector('.filter-btn[data-active="true"]') as HTMLElement | null
      const activeFilter = activeButton?.dataset.filter || "all"
      const query = normalizeSearch(searchInput.value || "")
      let visibleCount = 0

      tipCards.forEach((card) => {
        const el = card as HTMLElement
        const category = el.dataset.category || ""
        const indexedSearch = el.dataset.id ? searchState.index?.get(el.dataset.id) : ""
        const searchable = indexedSearch || el.dataset.search || ""
        const matchesCategory = activeFilter === "all" || category === activeFilter
        const matchesSearch = query.length === 0 || searchable.includes(query)
        const isVisible = matchesCategory && matchesSearch

        el.style.display = isVisible ? "block" : "none"
        if (isVisible) visibleCount += 1
      })

      if (searchStatus) {
        const label = searchStatus.dataset.resultsLabel || "resultados encontrados"
        searchStatus.textContent =
          searchInput.value.trim().length > 0 ? `${visibleCount} ${label}` : ""
      }
    }

    if (filterContainer?.dataset.filterBound !== "true") {
      filterContainer.dataset.filterBound = "true"
      filterContainer.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement | null)?.closest(".filter-btn")
        if (!button) return

        filterContainer.querySelectorAll(".filter-btn").forEach((btn) => {
          btn.setAttribute("data-active", "false")
          btn.setAttribute("aria-pressed", "false")
          btn.classList.remove("text-sky-400")
          btn.classList.add("text-neutral-600")
        })

        button.setAttribute("data-active", "true")
        button.setAttribute("aria-pressed", "true")
        button.classList.add("text-sky-400")
        button.classList.remove("text-neutral-600")
        applyFilters()
      })
    }

    if (searchInput.dataset.searchBound !== "true") {
      searchInput.dataset.searchBound = "true"
      searchInput.addEventListener("input", () => {
        const query = searchInput.value.trim()
        applyFilters()

        if (query.length > 0 && !searchState.index) {
          void loadSearchIndex().then(applyFilters)
        }
      })
    }
  }

  function handleSearchKeydown(event: KeyboardEvent) {
    const target = event.target as HTMLElement | null
    const tagName = target?.tagName?.toLowerCase()
    const isEditable =
      tagName === "input" ||
      tagName === "textarea" ||
      target?.isContentEditable

    if (event.key === "/" && !isEditable) {
      const searchInput = document.getElementById("tips-search") as HTMLInputElement | null
      if (searchInput) {
        event.preventDefault()
        searchInput.focus()
        searchInput.select()
      }
    }
  }

  if (document.documentElement.dataset.searchShortcutBound !== "true") {
    document.documentElement.dataset.searchShortcutBound = "true"
    document.addEventListener("keydown", handleSearchKeydown)
  }

  initSearch()
  document.addEventListener("astro:page-load", initSearch)
</script>
