---
import { useTranslations } from "../i18n/utils"
import { getRelativeLocaleUrl } from "astro:i18n"
import { routes } from "../i18n/ui"

interface Props {
  total?: number
  alternateUrl?: string
  showSearch?: boolean
}

const { total = 100, alternateUrl, showSearch = false } = Astro.props

const lang = (Astro.currentLocale || "es") as "es" | "en"
const t = useTranslations(lang)

const aboutPath = routes[lang].about
---

<nav
  id="navbar"
  aria-label={lang === "es" ? "Navegación principal" : "Main navigation"}
  data-total={total}
  class="navbar sticky top-0 z-50 border-b border-white/[0.06]"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center h-14 gap-4">

      <a
        href={getRelativeLocaleUrl(lang, "/")}
        class="navbar-logo group flex items-center gap-1.5 shrink-0"
      >
        <span class="font-pixel text-lg text-sky-400 tracking-tight leading-none">100</span>
        <span class="text-[13px] text-neutral-500 group-hover:text-neutral-300 transition-colors leading-none">cosas.dev</span>
      </a>

      {showSearch && (
        <div class="navbar-search hidden md:flex items-center flex-1 max-w-md mx-auto">
          <label for="tips-search" class="sr-only">{t("nav.search")}</label>
          <div class="relative w-full">
            <svg class="pointer-events-none absolute left-2.5 top-1/2 -translate-y-1/2 size-3.5 text-neutral-600" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
            </svg>
            <input
              id="tips-search"
              type="search"
              inputmode="search"
              autocomplete="off"
              spellcheck="false"
              aria-keyshortcuts="/"
              aria-describedby="tips-search-hint tips-search-status"
              placeholder={t("nav.search_placeholder")}
              class="navbar-search-input w-full rounded-lg border border-white/[0.06] bg-white/[0.03] pl-8 pr-10 py-1.5 text-[12px] text-neutral-200 placeholder:text-neutral-600 focus:border-sky-500/30 focus:bg-white/[0.05] transition-all"
            />
            <kbd class="pointer-events-none absolute right-2.5 top-1/2 -translate-y-1/2 rounded border border-white/[0.1] bg-white/[0.03] px-1.5 py-0.5 text-[10px] leading-none text-neutral-600 font-mono">/</kbd>
          </div>
          <span id="tips-search-hint" class="sr-only">{t("nav.search_shortcut")}</span>
          <span
            id="tips-search-status"
            data-results-label={t("nav.search_results")}
            class="sr-only"
            role="status"
            aria-live="polite"
            aria-atomic="true"
          ></span>
        </div>
      )}

      <div class="hidden md:flex items-center gap-1 shrink-0 ml-auto">
        <div class="navbar-progress flex items-center gap-2.5 px-2">
          <div class="w-20 h-[3px] bg-white/[0.06] rounded-full overflow-hidden">
            <div
              id="progress-bar"
              class="h-full bg-sky-500/80 rounded-full w-[0%]"
              style="transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);"
            >
            </div>
          </div>
          <span
            id="progress-text"
            role="status"
            aria-live="polite"
            aria-atomic="true"
            class="text-[11px] text-neutral-600 tabular-nums whitespace-nowrap"
            data-text-read={t("nav.read")}><span class="font-pixel text-sky-400/60">0/{total}</span> <span class="text-neutral-700">{t("nav.read")}</span></span
          >
        </div>

        <div class="navbar-separator"></div>

        <div class="flex items-center">
          <a
            href={getRelativeLocaleUrl(lang, `/${aboutPath}`)}
            class="navbar-link text-[12px] text-neutral-500 hover:text-neutral-200 transition-colors px-2.5 py-1.5 rounded-md hover:bg-white/[0.03]"
          >
            {t("nav.about")}
          </a>
          <a
            href="https://github.com/midudev/100cosas.dev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={lang === "es" ? "GitHub (se abre en una pestaña nueva)" : "GitHub (opens in a new tab)"}
            class="navbar-link text-[12px] text-neutral-500 hover:text-neutral-200 transition-colors px-2.5 py-1.5 rounded-md hover:bg-white/[0.03] flex items-center gap-1"
          >
            GitHub
            <svg class="size-3 opacity-40" viewBox="0 0 16 16" fill="currentColor">
              <path d="M4.53 4.75A.75.75 0 015.28 4h6.01a.75.75 0 01.75.75v6.01a.75.75 0 01-1.5 0V6.31l-5.263 5.263a.75.75 0 01-1.06-1.06L9.44 5.25H5.28a.75.75 0 01-.75-.75z" />
            </svg>
          </a>
        </div>

      </div>

      <!-- Mobile -->
      <div class="flex md:hidden items-center gap-3 ml-auto">
        {showSearch && (
          <button
            type="button"
            id="mobile-search-toggle"
            aria-label={t("nav.search")}
            class="text-neutral-500 hover:text-neutral-300 transition-colors p-1.5"
          >
            <svg class="size-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
            </svg>
          </button>
        )}

        <div class="flex items-center gap-2">
          <span
            id="progress-text-mobile"
            role="status"
            aria-live="polite"
            aria-atomic="true"
            class="text-[10px] font-pixel text-sky-400/60 tabular-nums leading-none">0/{total}</span
          >
          <div class="w-12 h-[3px] bg-white/[0.06] rounded-full overflow-hidden">
            <div
              id="progress-bar-mobile"
              class="h-full bg-sky-500/80 rounded-full w-[0%]"
              style="transition: width 0.5s ease;"
            >
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>

  {showSearch && (
    <div
      id="mobile-search-bar"
      class="md:hidden overflow-hidden transition-all duration-200 ease-out"
      style="max-height: 0;"
    >
      <div class="px-4 pb-3 pt-1">
        <label for="tips-search-mobile" class="sr-only">{t("nav.search")}</label>
        <div class="relative">
          <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 size-3.5 text-neutral-600" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
          <input
            id="tips-search-mobile"
            type="search"
            inputmode="search"
            autocomplete="off"
            spellcheck="false"
            placeholder={t("nav.search_placeholder")}
            class="navbar-search-input w-full rounded-lg border border-white/[0.06] bg-white/[0.03] pl-9 pr-4 py-2 text-[13px] text-neutral-200 placeholder:text-neutral-600 focus:border-sky-500/30 focus:bg-white/[0.05] transition-all"
          />
        </div>
      </div>
    </div>
  )}
</nav>

<style>
  .navbar {
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    background: rgba(5, 5, 5, 0.82);
  }

  .navbar-separator {
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.06);
    margin: 0 4px;
    flex-shrink: 0;
  }

  .navbar-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }
</style>

<script>
  const STORAGE_KEY = "read-tips"

  function getReadTips() {
    try {
      const stored = localStorage.getItem(STORAGE_KEY)
      if (!stored) return []
      const parsed = JSON.parse(stored)
      return Array.isArray(parsed) ? parsed : []
    } catch (e) {
      console.error("Error parsing read tips from localStorage", e)
      return []
    }
  }

  function saveReadTip(id: string, isRead: boolean) {
    try {
      const readTips = getReadTips()
      const newReadTips = isRead
        ? [...new Set([...readTips, id])]
        : readTips.filter((tipId: string) => tipId !== id)
      localStorage.setItem(STORAGE_KEY, JSON.stringify(newReadTips))
      updateProgress()
    } catch (e) {
      console.error("Error saving read tip to localStorage", e)
    }
  }

  function updateProgress() {
    const navbar = document.getElementById("navbar")
    const total = parseInt(navbar?.dataset.total || "100")
    const readTips = getReadTips()
    const count = readTips.length
    const percentage = Math.round((count / total) * 100)

    const progressBars = [
      document.getElementById("progress-bar"),
      document.getElementById("progress-bar-mobile"),
    ]
    const progressTexts = [
      document.getElementById("progress-text"),
      document.getElementById("progress-text-mobile"),
    ]

    progressBars.forEach((bar) => {
      if (bar) bar.style.width = `${percentage}%`
    })

    progressTexts.forEach((text) => {
      if (text) {
        const isMobile = text.id.includes("mobile")
        const readText = text.dataset.textRead || "leídos"
        text.textContent = isMobile
          ? `${count}/${total}`
          : `${count}/${total} ${readText}`
      }
    })
  }

  function handleCheckboxChange(e: Event) {
    const target = e.target as HTMLInputElement
    if (target && target.classList.contains("read-toggle")) {
      const id = target.getAttribute("data-id")
      const isChecked = target.checked
      if (id) saveReadTip(id, isChecked)
    }
  }

  function initMobileSearch() {
    const toggle = document.getElementById("mobile-search-toggle")
    const bar = document.getElementById("mobile-search-bar")
    const desktopInput = document.getElementById("tips-search") as HTMLInputElement | null
    const mobileInput = document.getElementById("tips-search-mobile") as HTMLInputElement | null

    if (toggle && bar) {
      toggle.addEventListener("click", () => {
        const isOpen = bar.style.maxHeight !== "0px" && bar.style.maxHeight !== ""
        if (isOpen) {
          bar.style.maxHeight = "0px"
        } else {
          bar.style.maxHeight = "60px"
          mobileInput?.focus()
        }
      })
    }

    if (desktopInput && mobileInput) {
      desktopInput.addEventListener("input", () => {
        mobileInput.value = desktopInput.value
      })
      mobileInput.addEventListener("input", () => {
        desktopInput.value = mobileInput.value
        desktopInput.dispatchEvent(new Event("input", { bubbles: true }))
      })
    }
  }

  function init() {
    const readTips = getReadTips()

    const checkboxes = document.querySelectorAll(".read-toggle")
    checkboxes.forEach((checkbox) => {
      const id = checkbox.getAttribute("data-id")
      ;(checkbox as HTMLInputElement).checked = readTips.includes(id)
    })

    updateProgress()
    initMobileSearch()
  }

  document.addEventListener("change", handleCheckboxChange)

  init()
  document.addEventListener("astro:page-load", init)
</script>
