{
	"compatibility_date": "2026-04-23",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "100cosas-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "100cosas.dev",
			"custom_domain": true
		}
	]
}